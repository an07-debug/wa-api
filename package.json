{
  "name": "wa-api",
  "version": "1.0.0",
  "description": "Personal Baileys-based WhatsApp API with DB-persisted auth, reconnect handling, and anti-ban send queue (typing simulation + randomized delay).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "baileys": "7.0.0-rc13",
    "express": "^4.19.2",
    "mongodb": "^6.8.0",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  }
}
